# ── Runtime ─────────────────────────────────────────────────────────────────
# Node environment: development | test | production
NODE_ENV=development
# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ── Data stores (defaults match docker-compose.yml) ─────────────────────────
# Postgres 16 connection string — ALL state lives here (capacity, ledger, ...)
DATABASE_URL=postgres://sycamore:sycamore@localhost:5432/sycamore
# Redis 7 connection string — queues (BullMQ), rate limits, idempotency keys
REDIS_URL=redis://localhost:6379

# ── Apps ────────────────────────────────────────────────────────────────────
# Port for the channel gateway webhook ingress (apps/gateway)
GATEWAY_PORT=3001
# Port for the Next.js PWA — trust pages, checkout, founder cockpit (apps/web)
WEB_PORT=3000

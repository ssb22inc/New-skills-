{
  "name": "haven",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "supabase db push",
    "db:seed": "tsx prisma/seed.ts",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:components": "vitest run tests/components",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report",
    "load:listings": "k6 run load-tests/k6/listings-load.js",
    "load:matching": "k6 run load-tests/k6/matching-load.js",
    "load:ai": "k6 run load-tests/k6/ai-endpoints-load.js",
    "load:stress": "k6 run load-tests/k6/stress-test.js",
    "load:spike": "k6 run load-tests/k6/spike-test.js",
    "artillery:listings": "artillery run load-tests/artillery/config.yml",
    "artillery:matches": "artillery run load-tests/artillery/matches.yml",
    "test:all": "npm run test:coverage && npm run e2e",
    "ci:test": "npm run test:coverage && npm run e2e -- --reporter=github"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-toast": "^1.2.19",
    "@sentry/nextjs": "^10.65.0",
    "@supabase/ssr": "^0.12.1",
    "@supabase/supabase-js": "^2.110.5",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "argon2": "^0.44.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "isomorphic-dompurify": "^3.18.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "openai": "^6.46.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "stripe": "^22.3.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@faker-js/faker": "^10.3.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "^28.1.0",
    "msw": "^2.12.10",
    "pino-pretty": "^13.0.0",
    "prisma": "^7.4.2",
    "supertest": "^7.2.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "@hono/node-server": ">=1.19.13",
    "postcss": ">=8.5.10"
  }
}

# =============================================================
# Haven — Local Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================

# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_publishable_key

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Rate Limiting (Upstash Redis) ─────────────────────────────
# Get these from https://console.upstash.com → your Redis database → REST API
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# ── Metrics ───────────────────────────────────────────────────
# Protects /api/metrics from public access.
# For local docker-compose, set this to match what prometheus-local.yml expects.
# For production, generate a strong random token: openssl rand -hex 32
METRICS_TOKEN=changeme-dev-token

# ── Backups (only needed when running scripts/backup.sh) ──────
BACKUP_ENCRYPTION_KEY=your_gpg_passphrase_min_32_chars
AWS_S3_BACKUP_BUCKET=haven-backups-your-account-id
SLACK_BACKUP_WEBHOOK=https://hooks.slack.com/services/your/webhook/url

# ── Incident Notifications ───────────────────────────────────
SLACK_INCIDENT_WEBHOOK=https://hooks.slack.com/services/your/incident/webhook

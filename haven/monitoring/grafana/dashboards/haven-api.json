{
  "dashboard": {
    "id": null,
    "title": "Haven - API Performance",
    "tags": ["haven", "api"],
    "timezone": "browser",
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "API Endpoints - Request Rate",
        "type": "table",
        "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{namespace=\"haven\",handler=~\"/api/.*\"}[5m])) by (handler, method)",
            "format": "table",
            "instant": true
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "renameByName": {
                "handler": "Endpoint",
                "method": "Method",
                "Value": "Requests/sec"
              }
            }
          }
        ]
      },
      {
        "id": 2,
        "title": "Listings API - Latency",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 8, "w": 12, "h": 6 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{handler=~\"/api/listings.*\"}[5m])) by (le))",
            "legendFormat": "P50"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{handler=~\"/api/listings.*\"}[5m])) by (le))",
            "legendFormat": "P95"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{handler=~\"/api/listings.*\"}[5m])) by (le))",
            "legendFormat": "P99"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "s" }
        }
      },
      {
        "id": 3,
        "title": "Matches API - Latency",
        "type": "timeseries",
        "gridPos": { "x": 12, "y": 8, "w": 12, "h": 6 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{handler=~\"/api/matches.*\"}[5m])) by (le))",
            "legendFormat": "P50"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{handler=~\"/api/matches.*\"}[5m])) by (le))",
            "legendFormat": "P95"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{handler=~\"/api/matches.*\"}[5m])) by (le))",
            "legendFormat": "P99"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "s" }
        }
      },
      {
        "id": 4,
        "title": "AI API - Latency",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 14, "w": 12, "h": 6 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{handler=~\"/api/ai/.*\"}[5m])) by (le, handler))",
            "legendFormat": "{{ handler }} P50"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{handler=~\"/api/ai/.*\"}[5m])) by (le, handler))",
            "legendFormat": "{{ handler }} P95"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "s" }
        }
      },
      {
        "id": 5,
        "title": "Error Rates by Endpoint",
        "type": "timeseries",
        "gridPos": { "x": 12, "y": 14, "w": 12, "h": 6 },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{namespace=\"haven\",status=~\"5..\"}[5m])) by (handler)",
            "legendFormat": "{{ handler }}"
          }
        ]
      },
      {
        "id": 6,
        "title": "Rate Limiting",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 20, "w": 12, "h": 6 },
        "targets": [
          {
            "expr": "sum(rate(rate_limit_hits_total{namespace=\"haven\"}[5m])) by (endpoint)",
            "legendFormat": "{{ endpoint }}"
          }
        ]
      },
      {
        "id": 7,
        "title": "Authentication Events",
        "type": "timeseries",
        "gridPos": { "x": 12, "y": 20, "w": 12, "h": 6 },
        "targets": [
          {
            "expr": "sum(rate(auth_attempts_total{namespace=\"haven\",status=\"success\"}[5m]))",
            "legendFormat": "Successful Logins"
          },
          {
            "expr": "sum(rate(auth_attempts_total{namespace=\"haven\",status=\"failure\"}[5m]))",
            "legendFormat": "Failed Logins"
          }
        ]
      }
    ]
  }
}

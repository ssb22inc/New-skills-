{
  "dashboard": {
    "id": null,
    "title": "Haven - Business Metrics",
    "tags": ["haven", "business"],
    "timezone": "browser",
    "refresh": "5m",
    "panels": [
      {
        "id": 1,
        "title": "Active Users (24h)",
        "type": "stat",
        "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "count(count by (user_id) (http_requests_total{namespace=\"haven\"}[24h]))",
            "legendFormat": "Users"
          }
        ]
      },
      {
        "id": 2,
        "title": "New Listings (24h)",
        "type": "stat",
        "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "increase(listings_created_total{namespace=\"haven\"}[24h])",
            "legendFormat": "Listings"
          }
        ]
      },
      {
        "id": 3,
        "title": "Matches Made (24h)",
        "type": "stat",
        "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "increase(matches_created_total{namespace=\"haven\"}[24h])",
            "legendFormat": "Matches"
          }
        ]
      },
      {
        "id": 4,
        "title": "Bookings (24h)",
        "type": "stat",
        "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "increase(bookings_created_total{namespace=\"haven\"}[24h])",
            "legendFormat": "Bookings"
          }
        ]
      },
      {
        "id": 5,
        "title": "User Signups Over Time",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 4, "w": 12, "h": 6 },
        "targets": [
          {
            "expr": "increase(user_signups_total{namespace=\"haven\"}[1h])",
            "legendFormat": "Signups"
          }
        ]
      },
      {
        "id": 6,
        "title": "Listing Views",
        "type": "timeseries",
        "gridPos": { "x": 12, "y": 4, "w": 12, "h": 6 },
        "targets": [
          {
            "expr": "sum(rate(listing_views_total{namespace=\"haven\"}[5m]))",
            "legendFormat": "Views/sec"
          }
        ]
      },
      {
        "id": 7,
        "title": "Match Actions",
        "type": "piechart",
        "gridPos": { "x": 0, "y": 10, "w": 8, "h": 6 },
        "targets": [
          {
            "expr": "sum(increase(match_actions_total{namespace=\"haven\"}[24h])) by (action)",
            "legendFormat": "{{ action }}"
          }
        ]
      },
      {
        "id": 8,
        "title": "Average Match Score",
        "type": "gauge",
        "gridPos": { "x": 8, "y": 10, "w": 8, "h": 6 },
        "targets": [
          {
            "expr": "avg(match_score{namespace=\"haven\"})",
            "legendFormat": "Avg Score"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "red", "value": null },
                { "color": "yellow", "value": 50 },
                { "color": "green", "value": 70 }
              ]
            }
          }
        }
      },
      {
        "id": 9,
        "title": "Conversion Funnel",
        "type": "bargauge",
        "gridPos": { "x": 16, "y": 10, "w": 8, "h": 6 },
        "targets": [
          {
            "expr": "sum(increase(funnel_step_total{namespace=\"haven\"}[24h])) by (step)",
            "legendFormat": "{{ step }}"
          }
        ]
      },
      {
        "id": 10,
        "title": "Revenue (Daily)",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 16, "w": 24, "h": 6 },
        "targets": [
          {
            "expr": "sum(increase(payment_amount_total{namespace=\"haven\",status=\"success\"}[24h]))",
            "legendFormat": "Revenue"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "currencyUSD" }
        }
      }
    ]
  }
}

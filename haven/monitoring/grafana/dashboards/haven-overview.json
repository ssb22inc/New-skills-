{
  "dashboard": {
    "id": null,
    "title": "Haven - Overview",
    "tags": ["haven", "overview"],
    "timezone": "browser",
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Request Rate",
        "type": "stat",
        "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{namespace=\"haven\"}[5m]))",
            "legendFormat": "Requests/sec"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area"
        }
      },
      {
        "id": 2,
        "title": "Error Rate",
        "type": "stat",
        "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{namespace=\"haven\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{namespace=\"haven\"}[5m])) * 100",
            "legendFormat": "Error %"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 1 },
                { "color": "red", "value": 5 }
              ]
            },
            "unit": "percent"
          }
        }
      },
      {
        "id": 3,
        "title": "P95 Latency",
        "type": "stat",
        "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{namespace=\"haven\"}[5m])) by (le))",
            "legendFormat": "P95"
          }
        ],
        "options": {
          "colorMode": "value"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 0.5 },
                { "color": "red", "value": 1 }
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Active Pods",
        "type": "stat",
        "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "count(kube_pod_status_phase{namespace=\"haven\",phase=\"Running\"})",
            "legendFormat": "Running Pods"
          }
        ]
      },
      {
        "id": 5,
        "title": "Request Rate Over Time",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{namespace=\"haven\"}[5m])) by (handler)",
            "legendFormat": "{{ handler }}"
          }
        ],
        "options": {
          "legend": { "displayMode": "table", "placement": "right" }
        }
      },
      {
        "id": 6,
        "title": "Response Time Distribution",
        "type": "heatmap",
        "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "sum(rate(http_request_duration_seconds_bucket{namespace=\"haven\"}[5m])) by (le)",
            "format": "heatmap",
            "legendFormat": "{{ le }}"
          }
        ]
      },
      {
        "id": 7,
        "title": "CPU Usage",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 12, "w": 8, "h": 6 },
        "targets": [
          {
            "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"haven\",container!=\"\"}[5m])) by (pod)",
            "legendFormat": "{{ pod }}"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "percentunit" }
        }
      },
      {
        "id": 8,
        "title": "Memory Usage",
        "type": "timeseries",
        "gridPos": { "x": 8, "y": 12, "w": 8, "h": 6 },
        "targets": [
          {
            "expr": "sum(container_memory_usage_bytes{namespace=\"haven\",container!=\"\"}) by (pod)",
            "legendFormat": "{{ pod }}"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "bytes" }
        }
      },
      {
        "id": 9,
        "title": "Network I/O",
        "type": "timeseries",
        "gridPos": { "x": 16, "y": 12, "w": 8, "h": 6 },
        "targets": [
          {
            "expr": "sum(rate(container_network_receive_bytes_total{namespace=\"haven\"}[5m]))",
            "legendFormat": "Received"
          },
          {
            "expr": "sum(rate(container_network_transmit_bytes_total{namespace=\"haven\"}[5m]))",
            "legendFormat": "Transmitted"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "Bps" }
        }
      },
      {
        "id": 10,
        "title": "HTTP Status Codes",
        "type": "piechart",
        "gridPos": { "x": 0, "y": 18, "w": 6, "h": 6 },
        "targets": [
          {
            "expr": "sum(increase(http_requests_total{namespace=\"haven\"}[1h])) by (status)",
            "legendFormat": "{{ status }}"
          }
        ]
      },
      {
        "id": 11,
        "title": "Top Endpoints by Request Count",
        "type": "bargauge",
        "gridPos": { "x": 6, "y": 18, "w": 9, "h": 6 },
        "targets": [
          {
            "expr": "topk(10, sum(rate(http_requests_total{namespace=\"haven\"}[5m])) by (handler))",
            "legendFormat": "{{ handler }}"
          }
        ]
      },
      {
        "id": 12,
        "title": "Pod Restarts",
        "type": "timeseries",
        "gridPos": { "x": 15, "y": 18, "w": 9, "h": 6 },
        "targets": [
          {
            "expr": "sum(kube_pod_container_status_restarts_total{namespace=\"haven\"}) by (pod)",
            "legendFormat": "{{ pod }}"
          }
        ]
      }
    ]
  }
}
